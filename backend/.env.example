# Environment Configuration
ENV_FOR_DYNACONF=development

# Credential Vault master key. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotate by setting newest first: CUBEPLEX_AUTH__VAULT_KEY=<new>,<old>
CUBEPLEX_AUTH__VAULT_KEY=

# LLM Provider API Keys (uncomment and set as needed)
CUBEPLEX_LLM__PROVIDERS__CUBEPLEX__BASE_URL=your-sensedeal-api-key
CUBEPLEX_LLM__PROVIDERS__CUBEPLEX__API_KEY=your-sensedeal-api-key

# CUBEPLEX_LLM__PROVIDERS__OPENAI__API_KEY=your-openai-api-key
# CUBEPLEX_LLM__PROVIDERS__ANTHROPIC__API_KEY=your-anthropic-api-key

# OpenSandbox Configuration
# CUBEPLEX_SANDBOX__DOMAIN=localhost:8090
# CUBEPLEX_SANDBOX__IMAGE=hub.sensedeal.vip/library/ubuntu:22.04
# CUBEPLEX_SANDBOX__API_KEY=your-sandbox-api-key

# Database Configuration
CUBEPLEX_DATABASE__HOST=localhost
CUBEPLEX_DATABASE__PORT=5432
CUBEPLEX_DATABASE__USER=postgres
CUBEPLEX_DATABASE__PASSWORD=postgres
CUBEPLEX_DATABASE__NAME=cubeplex

# Redis Configuration (when implemented)
# CUBEPLEX_REDIS__URL=redis://localhost:6379/0

# Elasticsearch Configuration (when implemented)
# CUBEPLEX_ELASTICSEARCH__URL=http://localhost:9200

# Public origins (used to build OAuth redirect_uri and the post-callback
# browser redirect). MUST be real public origins in production deploys —
# OAuth flows break or leak sessions if these point at localhost when
# the app is reachable on a public hostname.
CUBEPLEX_PUBLIC_BASE_URL=http://localhost:8000
CUBEPLEX_FRONTEND_BASE_URL=http://localhost:3000

# MCP OAuth App credentials for connectors that don't support Dynamic
# Client Registration (GitHub, Slack, Google Workspace). Register the
# OAuth App in each vendor's developer console, set the redirect URI
# to ${CUBEPLEX_PUBLIC_BASE_URL}/api/v1/oauth/mcp/callback, paste the
# resulting client_id / client_secret here. Then run
#   python -m cubeplex.cli seed-mcp-catalog
# from backend/ to load them into the system catalog. Connectors
# whose env vars are unset are skipped with a warning — the rest of
# the seed run continues.
# CUBEPLEX_MCP_OAUTH__GITHUB__CLIENT_ID=
# CUBEPLEX_MCP_OAUTH__GITHUB__CLIENT_SECRET=
# CUBEPLEX_MCP_OAUTH__SLACK__CLIENT_ID=
# CUBEPLEX_MCP_OAUTH__SLACK__CLIENT_SECRET=
# CUBEPLEX_MCP_OAUTH__GWS__CLIENT_ID=
# CUBEPLEX_MCP_OAUTH__GWS__CLIENT_SECRET=
