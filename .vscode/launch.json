{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend: Run Script",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "ENV_FOR_DYNACONF": "development",
                "CUBEBOX_DEBUG": "true"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Backend: Run API Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/main.py",
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "ENV_FOR_DYNACONF": "development",
                "CUBEBOX_DEBUG": "true"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Frontend: Dev Server",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "-F",
                "@cubebox/web",
                "dev"
            ],
            "cwd": "${workspaceFolder}/frontend",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "env": {
                "CUBEBOX_API_URL": "http://localhost:8000"
            }
        }
    ],
    "compounds": [
        {
            "name": "Full Stack: Frontend + Backend",
            "configurations": [
                "Backend: Run API Server",
                "Frontend: Dev Server"
            ],
            "stopAll": true
        }
    ]
}