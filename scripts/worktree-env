#!/usr/bin/env python3
"""worktree-env — allocate ports, PostgreSQL databases, and Redis prefixes per
git worktree so multiple worktrees can run dev servers and E2E in parallel.

See docs/superpowers/specs/2026-04-28-worktree-parallel-dev-isolation-design.md
"""

from __future__ import annotations

import re

# ------------------------------------------------------------------ slug

_SLUG_PUNCT = re.compile(r"[^a-z0-9]+")


def slugify(name: str) -> str:
    """Normalize a branch name into a slug usable in DNS, DB, Redis."""
    lowered = name.lower()
    replaced = _SLUG_PUNCT.sub("-", lowered)
    return replaced.strip("-")


# ---------------------------------------------------------------- registry

import json
import os
import sys
import types
from dataclasses import dataclass, field
from pathlib import Path

# When loaded via SourceFileLoader the module is not in sys.modules, which
# causes Python 3.13 dataclasses to fail resolving string annotations.
if __name__ not in sys.modules:
    _self_mod = types.ModuleType(__name__)
    _self_mod.__dict__.update(globals())
    sys.modules[__name__] = _self_mod


@dataclass
class Registry:
    """Per-main-repo allocation registry.

    Stored at <main_repo>/.worktrees/registry.json. Maps slug -> entry dict
    with keys: offset, branch, path, created_at.
    """

    path: Path
    entries: dict[str, dict] = field(default_factory=dict)

    @classmethod
    def load(cls, path: Path) -> "Registry":
        if not path.exists():
            return cls(path=path, entries={})
        try:
            data = json.loads(path.read_text())
        except json.JSONDecodeError as e:
            raise ValueError(f"registry at {path} is not valid JSON: {e}") from e
        if not isinstance(data, dict):
            raise ValueError(f"registry at {path} must be an object, got {type(data).__name__}")
        return cls(path=path, entries=data)

    def save(self) -> None:
        self.path.parent.mkdir(parents=True, exist_ok=True)
        tmp = self.path.with_suffix(self.path.suffix + ".tmp")
        tmp.write_text(json.dumps(self.entries, indent=2, sort_keys=True) + "\n")
        os.replace(tmp, self.path)


# -------------------------------------------------------------- allocation

import hashlib
from datetime import datetime, timezone

SLOT_RANGE = 100  # offsets 0..99


def _hash_slot(slug: str) -> int:
    """Stable hash of slug into 0..SLOT_RANGE-1."""
    digest = hashlib.sha1(slug.encode("utf-8")).hexdigest()
    return int(digest[:8], 16) % SLOT_RANGE


def allocate_offset(
    slug: str,
    registry: Registry,
    is_main_worktree: bool,
) -> int:
    """Return offset for slug, allocating a new slot if needed.

    - Main worktree always gets 0.
    - Existing slug returns its existing offset (idempotent).
    - New slug: hash to a starting slot, then linear-probe for the first
      free slot. Slot 0 is reserved for main.
    """
    if is_main_worktree:
        return 0

    if slug in registry.entries:
        return int(registry.entries[slug]["offset"])

    used = {int(e["offset"]) for e in registry.entries.values()}
    initial = _hash_slot(slug)
    if initial == 0:
        initial = 1  # never auto-pick reserved main slot

    slot = initial
    for _ in range(SLOT_RANGE):
        if slot != 0 and slot not in used:
            return slot
        slot = (slot + 1) % SLOT_RANGE
        if slot == 0:
            slot = 1

    raise RuntimeError(
        "all 100 slots taken; run `worktree-env clean-orphans` to reclaim"
    )


def check_slug_collision(
    registry: Registry,
    slug: str,
    branch: str,
) -> None:
    """Raise if `slug` is already registered to a different branch.

    slugify() is intentionally lossy (lowercases, collapses punctuation), so
    `feat/foo-bar` and `feat/foo_bar` (or `Feat/Foo` and `feat/foo`) all
    collapse to the same key. Without this guard, the second `init` would
    silently reuse the first's allocation slot AND overwrite its `path` —
    both worktrees would think they own the same schemas/Redis prefix, and
    a `destroy` from one would drop the other's data.

    Same slug + same branch is allowed (path may legitimately drift if the
    worktree was moved on disk; record_allocation will refresh the path).
    """
    existing = registry.entries.get(slug)
    if existing is None:
        return
    if existing["branch"] == branch:
        return
    raise RuntimeError(
        f"Slug collision: '{slug}' is already registered to branch "
        f"'{existing['branch']}' at {existing['path']}.\n"
        f"Branch '{branch}' slugifies to the same key but is a different "
        f"branch — slugify() is lossy across case and punctuation.\n"
        f"Resolve by either:\n"
        f"  1. Renaming branch '{branch}' to something that doesn't collide.\n"
        f"  2. Running `worktree-env destroy` from {existing['path']} first "
        f"if that worktree is no longer needed."
    )


def record_allocation(
    registry: Registry,
    slug: str,
    branch: str,
    offset: int,
    worktree_path: Path,
) -> None:
    registry.entries[slug] = {
        "offset": offset,
        "branch": branch,
        "path": str(worktree_path),
        "created_at": datetime.now(timezone.utc).isoformat(),
    }
    registry.save()


# --------------------------------------------------------------- discovery

import subprocess
from dataclasses import dataclass


@dataclass
class WorktreeInfo:
    path: Path        # absolute path to current worktree
    main_path: Path   # absolute path to main repo
    branch: str       # current branch name
    is_main: bool


def _git(args: list[str], cwd: Path | None = None) -> str:
    result = subprocess.run(
        ["git", *args],
        cwd=cwd,
        check=True,
        capture_output=True,
        text=True,
    )
    return result.stdout.strip()


def find_main_repo(start_dir: Path | None = None) -> Path:
    """Return the absolute path to the main repo (first entry of git worktree list)."""
    cwd = start_dir or Path.cwd()
    output = _git(["worktree", "list", "--porcelain"], cwd=cwd)
    for line in output.splitlines():
        if line.startswith("worktree "):
            return Path(line.removeprefix("worktree ")).resolve()
    raise RuntimeError(f"no worktrees found from {cwd}")


def current_worktree_info(start_dir: Path | None = None) -> WorktreeInfo:
    """Inspect the current working directory's worktree."""
    cwd = (start_dir or Path.cwd()).resolve()
    main = find_main_repo(cwd)
    here = Path(_git(["rev-parse", "--show-toplevel"], cwd=cwd)).resolve()
    branch = _git(["rev-parse", "--abbrev-ref", "HEAD"], cwd=cwd)
    return WorktreeInfo(
        path=here,
        main_path=main,
        branch=branch,
        is_main=(here == main),
    )


# ---------------------------------------------------------- env file write

ENV_FILE_NAME = ".worktree.env"


def env_file_path(worktree_root: Path) -> Path:
    return worktree_root / ENV_FILE_NAME


def db_dev_schema(slug: str) -> str:
    return f"cubeplex_{slug.replace('-', '_')}"


def db_test_schema(slug: str) -> str:
    return f"cubeplex_test_{slug.replace('-', '_')}"


def redis_prefix(slug: str) -> str:
    return f"cubeplex-{slug}"


def write_worktree_env(
    worktree_root: Path,
    slug: str,
    offset: int,
) -> None:
    """Write .worktree.env to worktree root with all derived values."""
    fe = 3000 + offset
    be = 8000 + offset
    # Slot-specific cookie names. Browsers scope cookies by host, not port —
    # without per-worktree names, all worktrees on localhost share the same
    # cookie jar and stale auth tokens cause /login → / redirect loops.
    auth_cookie = f"cubeplex_auth_{offset}"
    csrf_cookie = f"cubeplex_csrf_{offset}"
    content = (
        f"# Worktree: {slug} (slot {offset})\n"
        f"# Auto-generated by scripts/worktree-env init. Do not edit by hand.\n"
        f"CUBEPLEX_WORKTREE_NAME={slug}\n"
        f"CUBEPLEX_WORKTREE_SLOT={offset}\n"
        f"\n"
        f"# Backend\n"
        f"CUBEPLEX_API__HOST=127.0.0.1\n"
        f"CUBEPLEX_API__PORT={be}\n"
        f"CUBEPLEX_DATABASE__NAME={db_dev_schema(slug)}\n"
        f"CUBEPLEX_REDIS__KEY_PREFIX={redis_prefix(slug)}\n"
        f"CUBEPLEX_AUTH__COOKIE_NAME={auth_cookie}\n"
        f"CUBEPLEX_AUTH__CSRF_COOKIE_NAME={csrf_cookie}\n"
        f"\n"
        f"# Frontend (Next dev / SSR rewrite / Playwright)\n"
        f"CUBEPLEX_API_URL=http://localhost:{be}\n"
        f"PORT={fe}\n"
        f"BASE_URL=http://localhost:{fe}\n"
        f"NEXT_PUBLIC_AUTH_COOKIE_NAME={auth_cookie}\n"
        f"NEXT_PUBLIC_CSRF_COOKIE_NAME={csrf_cookie}\n"
        f"\n"
        f"# Backend: frontend URL for link generation (IM identity link etc.)\n"
        f"CUBEPLEX_FRONTEND_BASE_URL=http://localhost:{fe}\n"
        f"\n"
        f"# Disable the egress exchange mTLS listener — worktrees share the\n"
        f"# host network and the main backend already owns port 9443.\n"
        f"CUBEPLEX_EGRESS_EXCHANGE__LISTENER__ENABLED=false\n"
    )
    env_file_path(worktree_root).write_text(content)


# --------------------------------------------------------- postgres + alembic

def _pg_creds_from_env() -> dict[str, str]:
    """Read PG creds from CUBEPLEX_DATABASE__* env vars, with sane defaults.

    We re-read from os.environ because `init` already loaded .worktree.env
    earlier in this run; we want CUBEPLEX_DATABASE__HOST etc. that come from
    backend/.env (the secrets file).
    """
    return {
        "host": os.environ.get("CUBEPLEX_DATABASE__HOST", "localhost"),
        "port": os.environ.get("CUBEPLEX_DATABASE__PORT", "5432"),
        "user": os.environ.get("CUBEPLEX_DATABASE__USER", "postgres"),
        "password": os.environ.get("CUBEPLEX_DATABASE__PASSWORD", "postgres"),
    }


def _quote_ident(name: str) -> str:
    """Quote a PG identifier for safe inclusion in DDL."""
    if '"' in name:
        raise ValueError(f"refusing to quote identifier containing double quote: {name!r}")
    return f'"{name}"'


def _pg_exec(sql: str, db: str = "postgres") -> None:
    """Run a single SQL statement via the `psql` CLI against `db`."""
    creds = _pg_creds_from_env()
    cmd = [
        "psql",
        "-h", creds["host"],
        "-p", creds["port"],
        "-U", creds["user"],
        "-d", db,
        "-v", "ON_ERROR_STOP=1",
        "-tAc", sql,
    ]
    env = {**os.environ, "PGPASSWORD": creds["password"]}
    result = subprocess.run(cmd, capture_output=True, text=True, env=env)
    if result.returncode != 0:
        raise RuntimeError(
            f"psql command failed (exit {result.returncode}):\n"
            f"  cmd: {' '.join(cmd[:-1])} <sql>\n"
            f"  sql: {sql}\n"
            f"  stderr: {result.stderr.strip()}"
        )


def _create_schemas(slug: str) -> None:
    """Create per-worktree dev/test databases if absent."""
    dev = db_dev_schema(slug)
    test = db_test_schema(slug)
    creds = _pg_creds_from_env()
    env = {**os.environ, "PGPASSWORD": creds["password"]}
    for db_name in (dev, test):
        # PG has no CREATE DATABASE IF NOT EXISTS — pre-check via pg_database.
        out = subprocess.run(
            [
                "psql",
                "-h", creds["host"],
                "-p", creds["port"],
                "-U", creds["user"],
                "-d", "postgres",
                "-tAc",
                f"SELECT 1 FROM pg_database WHERE datname = '{db_name}';",
            ],
            capture_output=True,
            text=True,
            env=env,
            check=True,
        )
        if out.stdout.strip() != "1":
            _pg_exec(f"CREATE DATABASE {_quote_ident(db_name)};")
    print(f"→ ensured PG databases: {dev}, {test}")


def _drop_schemas(slug: str) -> None:
    """Drop per-worktree dev/test databases, terminating live connections first."""
    dev = db_dev_schema(slug)
    test = db_test_schema(slug)
    for db_name in (dev, test):
        _pg_exec(
            f"SELECT pg_terminate_backend(pid) FROM pg_stat_activity "
            f"WHERE datname = '{db_name}';"
        )
        _pg_exec(f"DROP DATABASE IF EXISTS {_quote_ident(db_name)};")
    print(f"→ dropped PG databases: {dev}, {test}")


def _uv_sync_all_extras(worktree_path: Path) -> None:
    """Install backend deps including test/dev extras so pytest works in this worktree.

    Without this, `uv run alembic` only pulls runtime + alembic deps, leaving
    pytest/pytest-asyncio/etc. missing — the worktree can run the dev server
    but not the test suite. We sync the same way `make dev-install` does.
    """
    backend = worktree_path / "backend"
    print(f"→ syncing backend deps (uv sync --all-extras) in {backend}")
    result = subprocess.run(
        ["uv", "sync", "--all-extras"],
        cwd=backend,
    )
    if result.returncode != 0:
        raise RuntimeError(f"uv sync --all-extras failed (exit {result.returncode}).")


def _pnpm_install_frontend(worktree_path: Path) -> None:
    """Install frontend deps so pre-push hooks (lint/type-check/build) work.

    Without this, the first ``git push`` fails inside ``frontend-check-ci``
    because ``node_modules`` is missing and ``tsc`` can't resolve imports.
    """
    frontend = worktree_path / "frontend"
    if not (frontend / "package.json").exists():
        return
    print(f"→ installing frontend deps (pnpm install --frozen-lockfile) in {frontend}")
    result = subprocess.run(
        ["pnpm", "install", "--frozen-lockfile"],
        cwd=frontend,
    )
    if result.returncode != 0:
        raise RuntimeError(f"pnpm install failed (exit {result.returncode}).")


def _alembic_upgrade(worktree_path: Path) -> None:
    """Run `alembic upgrade head` in the worktree's backend dir.

    The subprocess inherits this process's os.environ, which already has
    .worktree.env loaded — so alembic targets the worktree's dev schema.
    """
    backend = worktree_path / "backend"
    print(f"→ running alembic upgrade head in {backend}")
    result = subprocess.run(
        ["uv", "run", "alembic", "upgrade", "head"],
        cwd=backend,
    )
    if result.returncode != 0:
        raise RuntimeError(
            f"alembic upgrade head failed (exit {result.returncode}). "
            "Schema is left as-is per design (no rollback)."
        )


def _load_dotenv_into_environ(path: Path) -> None:
    """Minimal dotenv loader (stdlib only) — set keys not already present."""
    if not path.exists():
        return
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        os.environ.setdefault(key.strip(), value.strip())


# --------------------------------------------------------------- subcommands

import argparse


def _read_redis_url_from_env_file() -> str | None:
    """Fallback: read CUBEPLEX_REDIS__URL from backend/.env if not in os.environ."""
    info = current_worktree_info()
    env_file = info.path / "backend" / ".env"
    if not env_file.exists():
        return None
    for line in env_file.read_text().splitlines():
        if line.startswith("CUBEPLEX_REDIS__URL="):
            return line.split("=", 1)[1].strip()
    return None


def _redis_delete_prefix(prefix: str) -> int:
    """Delete every key matching `<prefix>:*` from the configured Redis URL.

    Returns the number of keys deleted. Uses redis-cli with --scan + xargs DEL.
    """
    redis_url = os.environ.get("CUBEPLEX_REDIS__URL") or _read_redis_url_from_env_file()
    if not redis_url:
        print("⚠ no CUBEPLEX_REDIS__URL set; skipping Redis cleanup", file=sys.stderr)
        return 0

    pattern = f"{prefix}:*"
    # SCAN keys
    scan = subprocess.run(
        ["redis-cli", "-u", redis_url, "--scan", "--pattern", pattern],
        capture_output=True,
        text=True,
        check=True,
    )
    keys = [k for k in scan.stdout.splitlines() if k]
    if not keys:
        return 0
    # DEL in chunks
    deleted = 0
    chunk_size = 500
    for i in range(0, len(keys), chunk_size):
        chunk = keys[i:i + chunk_size]
        result = subprocess.run(
            ["redis-cli", "-u", redis_url, "DEL", *chunk],
            capture_output=True,
            text=True,
            check=True,
        )
        deleted += int(result.stdout.strip() or 0)
    return deleted


def cmd_init(args: argparse.Namespace) -> int:
    info = current_worktree_info()
    slug = slugify(info.branch)

    registry_path = info.main_path / ".worktrees" / "registry.json"
    registry = Registry.load(registry_path)
    check_slug_collision(registry=registry, slug=slug, branch=info.branch)
    offset = allocate_offset(slug=slug, registry=registry, is_main_worktree=info.is_main)
    record_allocation(
        registry=registry,
        slug=slug,
        branch=info.branch,
        offset=offset,
        worktree_path=info.path,
    )

    print(f"→ slug={slug} slot={offset} branch={info.branch}")

    _copy_if_missing(
        info.main_path / "backend" / ".env",
        info.path / "backend" / ".env",
    )
    _copy_if_missing(
        info.main_path / "backend" / "config.development.local.yaml",
        info.path / "backend" / "config.development.local.yaml",
    )

    write_worktree_env(info.path, slug, offset)
    print(f"→ wrote {env_file_path(info.path)}")

    # Load .worktree.env FIRST so its CUBEPLEX_DATABASE__NAME wins over backend/.env
    # (which holds the main worktree's default 'cubeplex'). _load_dotenv_into_environ
    # uses setdefault, so first-loaded keys win. This mirrors config.py's order.
    # Backend's config.py will reload both at import time inside subprocesses.
    _load_dotenv_into_environ(env_file_path(info.path))
    _load_dotenv_into_environ(info.path / "backend" / ".env")

    _uv_sync_all_extras(info.path)
    _pnpm_install_frontend(info.path)
    _create_schemas(slug)
    _alembic_upgrade(info.path)

    return cmd_show(args)


def _copy_if_missing(src: Path, dst: Path) -> None:
    if dst.exists():
        return
    if not src.exists():
        print(f"⚠ missing source {src}; skipping copy", file=sys.stderr)
        return
    dst.parent.mkdir(parents=True, exist_ok=True)
    dst.write_bytes(src.read_bytes())
    print(f"→ copied {src.name} from main")


def cmd_show(args: argparse.Namespace) -> int:
    info = current_worktree_info()
    env_file = env_file_path(info.path)
    if not env_file.exists():
        print(f"No {ENV_FILE_NAME} at {info.path}.", file=sys.stderr)
        print("Run `./scripts/worktree-env init` from this worktree to allocate.", file=sys.stderr)
        return 1
    print(f"# Worktree: {info.path}")
    print(f"# Branch:   {info.branch}")
    print(f"# Main:     {info.main_path}")
    print(f"# is_main:  {info.is_main}")
    print()
    print(env_file.read_text(), end="")
    return 0


def cmd_destroy(args: argparse.Namespace) -> int:
    info = current_worktree_info()
    if info.is_main:
        print("Refusing to destroy main worktree allocation.", file=sys.stderr)
        return 1

    slug = slugify(info.branch)
    registry = Registry.load(info.main_path / ".worktrees" / "registry.json")

    # Refuse if the registry doesn't claim this worktree, or claims a different
    # path. Without this guard, destroying a detached-HEAD worktree (slug "head")
    # or a manually-created worktree could drop schemas owned by something else.
    entry = registry.entries.get(slug)
    if entry is None:
        print(
            f"Refusing to destroy: slug {slug!r} is not in the registry. "
            "Was this worktree created via `scripts/new-worktree`?",
            file=sys.stderr,
        )
        return 1
    if Path(entry["path"]).resolve() != info.path:
        print(
            f"Refusing to destroy: registry says slug {slug!r} lives at "
            f"{entry['path']}, but destroy was invoked from {info.path}.",
            file=sys.stderr,
        )
        return 1

    # Load env so DB creds are in os.environ. .worktree.env first so worktree
    # values win over backend/.env defaults (setdefault semantics).
    _load_dotenv_into_environ(env_file_path(info.path))
    _load_dotenv_into_environ(info.path / "backend" / ".env")

    _drop_schemas(slug)

    deleted = _redis_delete_prefix(redis_prefix(slug))
    print(f"→ deleted {deleted} Redis keys under prefix {redis_prefix(slug)}:*")

    del registry.entries[slug]
    registry.save()
    print(f"→ removed {slug} from registry")

    env_file = env_file_path(info.path)
    if env_file.exists():
        env_file.unlink()
        print(f"→ removed {env_file}")

    print(
        "Done. Run `git worktree remove <path>` separately to delete the worktree filesystem."
    )
    return 0


def cmd_reseed_db(args: argparse.Namespace) -> int:
    """Drop + recreate the worktree's dev/test databases and re-run all
    migrations from scratch.

    Why this exists: after a rebase that pulls in main migrations newer than
    the cubepi migration on this branch, alembic's stored revision pointer
    already shows ``head`` (because the worktree's DB had the branch's old
    head applied), so ``alembic upgrade head`` is a no-op even though the
    underlying tables are missing the columns those skipped migrations were
    supposed to add. Symptom: queries against the affected tables 500 with
    ``UndefinedColumn``. Manually ALTERing the missing columns works but is
    error-prone and easy to forget.

    This subcommand sidesteps that mess by destroying the worktree's
    databases and letting alembic re-apply the entire chain from base.

    DATA LOSS: drops every row in the worktree's dev + test databases.
    Conversations, runs, attachments, MCP installs, billing — all gone.
    Confirm with --yes or the prompt.
    """
    info = current_worktree_info()
    if info.is_main:
        print("Refusing to reseed-db on the main worktree.", file=sys.stderr)
        return 1

    slug = slugify(info.branch)
    registry = Registry.load(info.main_path / ".worktrees" / "registry.json")

    entry = registry.entries.get(slug)
    if entry is None:
        print(
            f"Refusing to reseed-db: slug {slug!r} is not in the registry. "
            "Was this worktree created via `scripts/new-worktree`?",
            file=sys.stderr,
        )
        return 1
    if Path(entry["path"]).resolve() != info.path:
        print(
            f"Refusing to reseed-db: registry says slug {slug!r} lives at "
            f"{entry['path']}, but reseed-db was invoked from {info.path}.",
            file=sys.stderr,
        )
        return 1

    dev = db_dev_schema(slug)
    test = db_test_schema(slug)
    if not args.yes:
        print(
            f"This will DROP and recreate {dev} + {test}, then run "
            f"`alembic upgrade head`."
        )
        resp = input("Type 'yes' to proceed: ").strip().lower()
        if resp != "yes":
            print("Aborted.")
            return 1

    # Load env so DB creds + worktree DB names are in os.environ. Order mirrors
    # cmd_destroy / cmd_init: .worktree.env first (setdefault semantics).
    _load_dotenv_into_environ(env_file_path(info.path))
    _load_dotenv_into_environ(info.path / "backend" / ".env")

    _drop_schemas(slug)
    _create_schemas(slug)
    _alembic_upgrade(info.path)

    print("Done. Worktree databases reseeded from base; alembic at head.")
    return 0


def cmd_doctor(args: argparse.Namespace) -> int:
    info = current_worktree_info()
    slug = slugify(info.branch)
    issues: list[str] = []

    # 1. .worktree.env exists
    env_file = env_file_path(info.path)
    if not env_file.exists():
        issues.append(f"missing {env_file} — run `worktree-env init`")
        # Print and bail; rest of checks need the env file
        for issue in issues:
            print(f"✗ {issue}", file=sys.stderr)
        return 1
    print(f"✓ {env_file} present")

    # Load env so we can probe PostgreSQL / Redis with current creds.
    # .worktree.env first so worktree DB name wins over backend/.env's default.
    _load_dotenv_into_environ(env_file)
    _load_dotenv_into_environ(info.path / "backend" / ".env")

    # 2. Registry entry consistent
    registry = Registry.load(info.main_path / ".worktrees" / "registry.json")
    entry = registry.entries.get(slug)
    if entry is None:
        issues.append(f"slug {slug} missing from registry")
    elif Path(entry["path"]).resolve() != info.path:
        issues.append(
            f"registry path drift: registry={entry['path']} actual={info.path}"
        )
    else:
        print(f"✓ registry entry slot={entry['offset']}")

    # 3. PostgreSQL databases exist
    try:
        _pg_exec("SELECT 1;", db=db_dev_schema(slug))
        print(f"✓ PG database {db_dev_schema(slug)} reachable")
    except RuntimeError as e:
        issues.append(f"dev database unusable: {e}")
    try:
        _pg_exec("SELECT 1;", db=db_test_schema(slug))
        print(f"✓ PG database {db_test_schema(slug)} reachable")
    except RuntimeError as e:
        issues.append(f"test database unusable: {e}")

    # 4. Redis reachable
    redis_url = os.environ.get("CUBEPLEX_REDIS__URL")
    if redis_url:
        result = subprocess.run(
            ["redis-cli", "-u", redis_url, "PING"],
            capture_output=True,
            text=True,
        )
        if result.returncode == 0 and result.stdout.strip() == "PONG":
            print("✓ Redis reachable")
        else:
            issues.append(f"Redis not reachable: {result.stderr or result.stdout}")
    else:
        issues.append("CUBEPLEX_REDIS__URL not set")

    # 5. Alembic head matches latest migration
    backend = info.path / "backend"
    cur = subprocess.run(
        ["uv", "run", "alembic", "current"],
        cwd=backend,
        capture_output=True,
        text=True,
    )
    head = subprocess.run(
        ["uv", "run", "alembic", "heads"],
        cwd=backend,
        capture_output=True,
        text=True,
    )
    if cur.returncode == 0 and head.returncode == 0:
        cur_rev = (cur.stdout.strip().split() or [""])[0]
        head_rev = (head.stdout.strip().split() or [""])[0]
        if cur_rev and cur_rev == head_rev:
            print(f"✓ alembic at head ({head_rev})")
        else:
            issues.append(f"alembic not at head: current={cur_rev} head={head_rev}")
    else:
        issues.append("alembic check failed")

    if issues:
        print()
        for issue in issues:
            print(f"✗ {issue}", file=sys.stderr)
        return 1
    return 0


def cmd_clean_orphans(args: argparse.Namespace) -> int:
    info = current_worktree_info()

    # 1. Find live worktree paths according to git
    live_paths: set[Path] = set()
    output = _git(["worktree", "list", "--porcelain"], cwd=info.main_path)
    for line in output.splitlines():
        if line.startswith("worktree "):
            live_paths.add(Path(line.removeprefix("worktree ")).resolve())

    # 2. Orphan registry entries
    registry = Registry.load(info.main_path / ".worktrees" / "registry.json")
    orphan_slugs: list[str] = []
    for slug, entry in registry.entries.items():
        entry_path = Path(entry["path"]).resolve()
        if entry_path not in live_paths:
            orphan_slugs.append(slug)

    # 3. Orphan PG databases (cubeplex_* not referenced by any live entry)
    referenced_dev = {db_dev_schema(s) for s in registry.entries if s not in orphan_slugs}
    referenced_test = {db_test_schema(s) for s in registry.entries if s not in orphan_slugs}
    referenced = referenced_dev | referenced_test | {"cubeplex", "cubeplex_test"}

    # Load main's backend/.env for PG creds
    _load_dotenv_into_environ(info.main_path / "backend" / ".env")

    creds = _pg_creds_from_env()
    list_result = subprocess.run(
        [
            "psql",
            "-h", creds["host"],
            "-p", creds["port"],
            "-U", creds["user"],
            "-d", "postgres",
            "-tAc",
            "SELECT datname FROM pg_database WHERE datname LIKE 'cubeplex_%';",
        ],
        capture_output=True,
        text=True,
        env={**os.environ, "PGPASSWORD": creds["password"]},
        check=True,
    )
    all_schemas = {s.strip() for s in list_result.stdout.splitlines() if s.strip()}
    orphan_schemas = sorted(all_schemas - referenced)

    if not orphan_slugs and not orphan_schemas:
        print("No orphans found.")
        return 0

    print("The following orphans will be cleaned:")
    for slug in orphan_slugs:
        print(f"  registry: {slug} -> {registry.entries[slug]['path']}")
    for schema in orphan_schemas:
        print(f"  schema:   {schema}")
    print()

    answer = input("Proceed? [y/N] ").strip().lower()
    if answer != "y":
        print("Aborted.")
        return 1

    for slug in orphan_slugs:
        del registry.entries[slug]
    registry.save()

    for schema in orphan_schemas:
        _pg_exec(
            f"SELECT pg_terminate_backend(pid) FROM pg_stat_activity "
            f"WHERE datname = '{schema}';"
        )
        _pg_exec(f"DROP DATABASE IF EXISTS {_quote_ident(schema)};")

    print(f"→ pruned {len(orphan_slugs)} registry entries, dropped {len(orphan_schemas)} databases")
    return 0


# --------------------------------------------------------------------- main


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="worktree-env",
        description="Allocate ports / DB schemas / Redis prefix per worktree.",
    )
    sub = parser.add_subparsers(dest="cmd", required=True)
    sub.add_parser("init", help="Allocate slot and provision the current worktree")
    sub.add_parser("show", help="Print current worktree's allocations")
    sub.add_parser("doctor", help="Verify schema, ports, services")
    sub.add_parser("destroy", help="Drop schemas, clear Redis prefix, remove .worktree.env")
    sub.add_parser("clean-orphans", help="Reclaim slots from removed worktrees")
    reseed_parser = sub.add_parser(
        "reseed-db",
        help="Drop + recreate worktree DBs and re-run all migrations from base "
        "(after a rebase introduces main migrations the alembic state already skipped)",
    )
    reseed_parser.add_argument(
        "--yes",
        action="store_true",
        help="Skip the confirmation prompt (still refuses on main worktree)",
    )

    args = parser.parse_args(argv)
    handlers = {
        "init": cmd_init,
        "show": cmd_show,
        "doctor": cmd_doctor,
        "destroy": cmd_destroy,
        "clean-orphans": cmd_clean_orphans,
        "reseed-db": cmd_reseed_db,
    }
    return handlers[args.cmd](args)


if __name__ == "__main__":
    sys.exit(main())
