# Operator-local overrides for cubeplex helm install.
# Copy this file to `values.local.yaml` on the operator workstation (NOT
# committed — gitignored via `*.local.yaml`). Fill in real secrets and
# model provider keys.
#
# Apply: helm upgrade --install cubeplex ./deploy/charts/cubeplex \
#          -n cubeplex --create-namespace \
#          -f values.yaml -f values.local.yaml

# Image tag defaults to the chart's appVersion (v<appVersion>), so a release
# chart already points at matching images — usually leave `image` unset.
# Override only to pin a different version or use a self-built / private image:
# image:
#   registry: "your-registry.example.com"   # self-built / private mirror
#   repository: "cubeplex"
#   backend:  { tag: "<YYMMDD>-<branch>-<short-sha>" }
#   frontend: { tag: "<YYMMDD>-<branch>-<short-sha>" }

backend:
  secrets:
    auth:
      # openssl rand -hex 32
      jwt_secret: "REPLACE_ME"
      csrf_secret: "REPLACE_ME"
      # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
      vault_key: "REPLACE_ME"
    # Mirror of backend/config.development.local.yaml `llm` block. Written
    # verbatim into the backend Secret as config.production.secrets.yaml.
    llm:
      default_model: "openai/gpt-5.6-terra"
      providers:
        # Any OpenAI-compatible endpoint (OpenAI, Azure, vLLM, LiteLLM, a gateway…).
        openai:
          base_url: "https://api.openai.com/v1"   # includes /v1
          api_key: "sk-..."
          api: "openai-completions"
          models:
            - id: "gpt-5.6-terra"
              name: "GPT-5.6 Terra"
              input: ["text", "image"]
              context_window: 128000
              max_tokens: 16384
        # Anthropic-compatible endpoint (base_url is the host root, no /v1):
        # anthropic:
        #   base_url: "https://api.anthropic.com"
        #   api_key: "sk-ant-..."
        #   api: "anthropic-messages"
        #   models:
        #     - { id: "claude-opus-4.8", name: "Claude Opus 4.8", reasoning: true,
        #         input: ["text", "image"], context_window: 200000, max_tokens: 64000 }
        # Shortcut for a known vendor via a built-in preset:
        # deepseek:
        #   preset: "deepseek/cn/anthropic-messages"
        #   api_key: "sk-..."
    sandbox:
      domain: "cubeplex-opensandbox-server.cubeplex.svc.cluster.local:8090"
      image: "ghcr.io/cubeplexai/cubeplex-sandbox:sandbox-v0.1.0"
      api_key: "REPLACE_ME"

# Flip backend.sandbox.enabled if you're using an external sandbox endpoint
# (backend.secrets.sandbox.domain) WITHOUT deploying the OpenSandbox subchart.
# backend:
#   sandbox:
#     enabled: true
#     use_server_proxy: false

postgres:
  auth:
    password: "REPLACE_ME"

redis:
  auth:
    password: "REPLACE_ME"

rustfs:
  auth:
    secretKey: "REPLACE_ME"

# ── Egress secret-injection (opt-in) ─────────────────────────────────────
# Enables the MITM webhook + backend mTLS exchange. The egress-webhook image
# ships with each GHCR release (self-builders append `egress-webhook` to
# TARGET when running build-and-push.sh).
#
# egress:
#   enabled: true
#   sandboxNamespace: "opensandbox-system"
#   webhook:
#     image:
#       tag: "v0.2.0"                        # same release version as backend/frontend
#     # MUST match opensandbox-server's configured egress.image exactly:
#     # China mirror: sandbox-registry.cn-zhangjiakou.cr.aliyuncs.com/opensandbox/egress:v1.0.12
#     egressImage: "opensandbox/egress:v1.0.12"
