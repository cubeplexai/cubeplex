# cubeplex docker-compose .env (template).
#
# Copy this file to `.env` next to compose.yaml and fill in real values.
# `.env` is gitignored. Do NOT commit secrets.

# ── Image source ─────────────────────────────────────────────────────────
# Defaults pull the public prebuilt release images from GHCR. Pick a release
# version tag from https://github.com/cubeplexai/cubeplex/releases (backend and
# frontend share the app version, e.g. v0.3.0).
# To build your own instead, run deploy/kubernetes/scripts/build-and-push.sh
# and point IMAGE_REGISTRY / IMAGE_REPO at your registry.
IMAGE_REGISTRY=ghcr.io
IMAGE_REPO=cubeplexai
BACKEND_TAG=v0.3.0
FRONTEND_TAG=v0.3.0

# ── Host port mappings ───────────────────────────────────────────────────
# What ports the host exposes. Frontend is the user entrypoint.
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Bundled infrastructure ───────────────────────────────────────────────
# Passwords: openssl rand -hex 16
POSTGRES_PASSWORD=REPLACE_ME
REDIS_PASSWORD=REPLACE_ME

# rustfs (S3-compatible object store)
RUSTFS_ACCESS_KEY=cubeplex
RUSTFS_SECRET_KEY=REPLACE_ME
# RUSTFS_IMAGE=rustfs/rustfs:latest

# Optional overrides (defaults shown):
# POSTGRES_USER=cubeplex
# POSTGRES_DB=cubeplex
# OBJECTSTORE_BUCKET=cubeplex

# ── Optional: OpenSandbox overlay (see compose.opensandbox.yaml) ─────────
# Only needed if you start the stack with -f compose.opensandbox.yaml.
# OPENSANDBOX_IMAGE=opensandbox/server:latest
# OPENSANDBOX_PORT=8090

# ── Optional: docling document-parsing overlay (see compose.docling.yaml) ─
# Only needed if you start the stack with -f compose.docling.yaml.
# DOCLING_REGISTRY=ghcr.io/docling-project
# DOCLING_CPU_TAG=v1.16.1
# DOCLING_CPU_PORT=5001
# DOCLING_CU130_TAG=v1.16.1
# DOCLING_CU130_PORT=5002
# HF_ENDPOINT=https://huggingface.co
# HF_TOKEN=
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,utility
