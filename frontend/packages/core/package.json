{
  "name": "@cubeplex/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "source": "./src/api/index.ts",
      "import": "./src/api/index.ts",
      "default": "./src/api/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "source": "./src/auth/index.ts",
      "import": "./src/auth/index.ts",
      "default": "./src/auth/index.ts"
    },
    "./stores": {
      "types": "./src/stores/index.ts",
      "source": "./src/stores/index.ts",
      "import": "./src/stores/index.ts",
      "default": "./src/stores/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "source": "./src/types/index.ts",
      "import": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./hooks/useDeploymentMode": {
      "types": "./src/hooks/useDeploymentMode.ts",
      "source": "./src/hooks/useDeploymentMode.ts",
      "import": "./src/hooks/useDeploymentMode.ts",
      "default": "./src/hooks/useDeploymentMode.ts"
    },
    "./hooks/useUserEvents": {
      "types": "./src/hooks/useUserEvents.ts",
      "source": "./src/hooks/useUserEvents.ts",
      "import": "./src/hooks/useUserEvents.ts",
      "default": "./src/hooks/useUserEvents.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src __tests__ --max-warnings=0",
    "format:check": "prettier --check \"{src,__tests__}/**/*.{ts,tsx,json}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "swr": "^2.4.1",
    "zustand": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@vitest/ui": "^4.1.2",
    "jsdom": "^29.0.1",
    "react": "19.2.4",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "19.2.4"
  }
}
