{
  "name": "@cubebox/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "source": "./src/api/index.ts",
      "default": "./dist/api/index.js"
    },
    "./stores": {
      "source": "./src/stores/index.ts",
      "default": "./dist/stores/index.js"
    },
    "./types": {
      "source": "./src/types/index.ts",
      "default": "./dist/types/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "zustand": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3"
  }
}
